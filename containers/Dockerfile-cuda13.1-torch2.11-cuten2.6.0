FROM nvidia/cuda:13.1.1-devel-ubuntu24.04

# Update and install Python and dependencies
RUN apt-get update && \
    apt-get install -y \
        python3 \
        python3-pip \
        python3-dev \
        python3-venv \
        python3-setuptools \
        python3-wheel \
        ca-certificates \
        git \
        wget \
        build-essential \
        && rm -rf /var/lib/apt/lists/*

ENV PIP_BREAK_SYSTEM_PACKAGES=1
RUN python3 -m pip config set global.break-system-packages true && \
    echo "[DEBUG] $(pip --version)"

RUN pip install torch

# Install common scientific computing packages
RUN pip install cmake numpy scipy matplotlib pandas pytest expecttest opt_einsum h5py tqdm

ENV CUDA_HOME=/usr/local/cuda

# Install cuTENSOR 2.6.0 (multi-arch: x86_64 and sbsa/arm64)
RUN if [ "$(uname -m)" = "x86_64" ]; then \
        CUTENSOR_DIR="linux-x86_64"; TARGETS_DIR="x86_64-linux"; \
    else \
        CUTENSOR_DIR="linux-sbsa"; TARGETS_DIR="sbsa-linux"; \
    fi && \
    CUTENSOR_PKG="libcutensor-${CUTENSOR_DIR}-2.6.0.4_cuda13-archive.tar.xz" && \
    wget -q "https://developer.download.nvidia.com/compute/cutensor/redist/libcutensor/${CUTENSOR_DIR}/${CUTENSOR_PKG}" && \
    tar -xf "${CUTENSOR_PKG}" -C "${CUDA_HOME}/targets/${TARGETS_DIR}" --strip-components=1 && \
    rm "${CUTENSOR_PKG}"

ENV CUTENSOR_ROOT=${CUDA_HOME}

# Clone yastn
RUN git clone --depth 1 --recurse-submodules --shallow-submodules https://github.com/yastn/yastn.git /opt/yastn

# Install TAPP-torch
RUN cd /opt/yastn/third_party/TAPP-torch && git fetch origin && git checkout -B main origin/main && \
    export TAPP_CUTENSOR_BINDINGS="ON" && \
    export TORCH_CUDA_ARCH_LIST="8.0;8.6;8.9;9.0;12.0" && \
    pip install -v --no-build-isolation -e .